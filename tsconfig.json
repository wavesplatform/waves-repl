{
  "compilerOptions": {
    "strict": true,
    "target": "es6",
    "jsx": "react",

    "module": "commonjs",
    "rootDir": ".",
    "lib": [
      "es7",
      "dom"
    ],
    "typeRoots": [
      "node_modules/@types",
      "typings"
    ],
    "declaration": true,
    "outDir": "dist",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "examples/**/*",
    "typings/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/node_modules/**"
  ]
}
